{
  "name": "mowen-publish",
  "version": "1.6.0",
  "type": "module",
  "description": "墨问文章发布 CLI 工具",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mowen-publish": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/momolibrary/mowen-publish.git"
  },
  "keywords": [
    "mowen",
    "markdown",
    "cli",
    "publish"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/momolibrary/mowen-publish/issues"
  },
  "homepage": "https://github.com/momolibrary/mowen-publish#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.0.0"
  }
}
